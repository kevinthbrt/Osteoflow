# Myosteoflow Desktop - Variables d'environnement
# Copiez ce fichier en .env.local

# Les données sont stockées localement en SQLite

# Optionnel: Clé API Resend (utilisée uniquement si aucun SMTP n'est configuré dans les paramètres)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@votre-domaine.fr

# App
NEXT_PUBLIC_APP_URL=http://localhost:3456

# Survey Worker (Cloudflare Worker pour les questionnaires patients)
SURVEY_WORKER_URL=https://myosteoflow-survey.myosteoflow.workers.dev
NEXT_PUBLIC_SURVEY_WORKER_URL=https://myosteoflow-survey.myosteoflow.workers.dev

# Osteoupgrade licence — URL de l'API de vérification de licence
# En production : https://osteoupgrade.vercel.app  (valeur par défaut si absent)
NEXT_PUBLIC_OSTEOUPGRADE_URL=https://osteoupgrade.vercel.app

# Secret partagé avec le proxy IA Osteoupgrade (généré via openssl rand -hex 32)
OSTEOFLOW_PROXY_SECRET=...

# Groq API — transcription vocale (Whisper large-v3-turbo, gratuit jusqu'à 7200s/jour)
# Créer une clé sur https://console.groq.com/keys
GROQ_API_KEY=gsk_...
